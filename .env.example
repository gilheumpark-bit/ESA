# ========================================
# ESA Environment Variables
# Names align with src/lib/env.ts and src/lib/server-ai.ts
# ========================================

# --- AI providers (BYOK: all optional server-side; users may pass keys in-app) ---
# Gemini (@ai-sdk/google / server-ai "gemini")
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
# Claude / Anthropic (not CLAUDE_API_KEY)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
# Groq (Llama 4 / Mixtral inference)
GROQ_API_KEY=
# Local LLM base URLs (optional; see server-ai ENV_KEY_MAP)
OLLAMA_BASE_URL=
LMSTUDIO_BASE_URL=

# --- Firebase Auth (NEXT_PUBLIC_* required for client; match env.ts) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (optional until billing is enabled) ---
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_ID=
STRIPE_PRICE_TEAM_ID=

# --- Weaviate (optional) ---
WEAVIATE_URL=
WEAVIATE_API_KEY=
# Embedding provider for Weaviate vectorization: 'openai' | 'google'
EMBEDDING_PROVIDER=openai

# --- Sentry (optional; env.ts uses NEXT_PUBLIC_SENTRY_DSN) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- ESA tunables (optional; see src/lib/esa-config.ts) ---
# ESA_DEFAULT_TENANT_ID=esa
# ESA_RAG_ALPHA=0.7
# ESA_RAG_FETCH_CAP=50
# ESA_RAG_SNIPPET_MAX_CHARS=500
# ESA_RAG_FRESHNESS_MAX_BOOST=1.15
# ESA_RAG_FRESHNESS_HALF_LIFE_DAYS=365

# --- App / runtime ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ALLOWED_ORIGINS=
NODE_ENV=development
LOG_LEVEL=info
OPEN_BETA=true

# --- Optional: Vertex / agent tooling (not referenced in src yet; keep if you deploy ingestion) ---
GCP_PROJECT_ID=
VERTEX_AI_CREDENTIALS=
AGENT_BUILDER_ESA_ID=
AGENT_BUILDER_LOCATION=us
