# ========================================
# ESA Environment Variables
# Names align with src/lib/env.ts and src/lib/server-ai.ts
# ========================================

# --- AI providers (BYOK: all optional server-side; users may pass keys in-app) ---
# Gemini (@ai-sdk/google / server-ai "gemini")
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
# Claude / Anthropic (not CLAUDE_API_KEY)
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
# Groq (Llama 4 / Mixtral inference)
GROQ_API_KEY=
# Local LLM base URLs (optional; see server-ai ENV_KEY_MAP)
OLLAMA_BASE_URL=
LMSTUDIO_BASE_URL=

# --- Firebase Auth (NEXT_PUBLIC_* required for client; match env.ts) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (optional until billing is enabled) ---
STRIPE_BILLING_ENABLED=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=

# --- Weaviate (optional) ---
WEAVIATE_URL=
WEAVIATE_API_KEY=
# Embedding provider for Weaviate vectorization: 'openai' | 'google'
EMBEDDING_PROVIDER=openai

# --- Sentry (optional; env.ts uses NEXT_PUBLIC_SENTRY_DSN) ---
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# --- ESA tunables (optional; see src/lib/esa-config.ts) ---
# ESA_DEFAULT_TENANT_ID=esa
# ESA_RAG_ALPHA=0.7
# ESA_RAG_FETCH_CAP=50
# ESA_RAG_SNIPPET_MAX_CHARS=500
# ESA_RAG_FRESHNESS_MAX_BOOST=1.15
# ESA_RAG_FRESHNESS_HALF_LIFE_DAYS=365

# --- App / runtime ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ALLOWED_ORIGINS=
NODE_ENV=development
LOG_LEVEL=info
OPEN_BETA=true
# 운영에서 메모리 저장을 영구 저장처럼 취급하지 않도록 false 유지.
ESVA_ALLOW_EPHEMERAL_STORAGE=false

# --- Optional: Vertex / agent tooling (not referenced in src yet; keep if you deploy ingestion) ---
GCP_PROJECT_ID=
VERTEX_AI_CREDENTIALS=
AGENT_BUILDER_ESA_ID=
AGENT_BUILDER_LOCATION=us

# 서버 간 내부 호출 인증용 공유 시크릿 (미설정 시 내부 우회 비활성·fail-closed)
INTERNAL_API_SECRET=
FEEDBACK_IP_HASH_SECRET=
CONTACT_IP_HASH_SECRET=
FIELD_SOS_RECIPIENT_UIDS=
# CI가 서명한 SLD 실도면 golden gate 영수증의 Ed25519 공개키(PEM).
# 미설정 시 95% 표시는 fail-closed로 비활성화됩니다. 멀티라인 값은 \\n 사용 가능.
SLD_GOLDEN_GATE_PUBLIC_KEY_PEM=
# 기본값은 fixtures/drawings/golden/sld-golden-manifest.json 및
# test-results/sld-golden-gate.json. 지정 시 프로젝트 루트 내부 상대경로만 허용됩니다.
SLD_GOLDEN_MANIFEST_PATH=
SLD_GOLDEN_RECEIPT_PATH=
# /api/health 상세 의존성·런타임 정보를 조회할 운영 전용 Bearer 토큰.
# 미설정 시 공개 응답은 overall status와 timestamp만 반환한다.
HEALTHCHECK_TOKEN=

# 서버가 접속해도 되는 On-Premise AI origin의 정확한 허용목록(쉼표 구분).
# 예: http://127.0.0.1:11434,http://192.168.1.100:8000
ONPREMISE_ALLOWED_ORIGINS=
