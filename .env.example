# ESVA environment variables
# Copy to .env.local and fill only the services used by the deployment.
# Never commit real keys, tokens, private keys, or company data paths.

# AI providers. Server keys are optional when users supply BYOK.
GOOGLE_GENERATIVE_AI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
MISTRAL_API_KEY=
GROQ_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
LMSTUDIO_BASE_URL=http://localhost:1234
NEXT_PUBLIC_DEFAULT_CHAT_MODEL=

# Firebase client and Admin token verification.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
FIREBASE_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# Supabase persistence. Service role is server-only.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Stripe. Keep disabled until keys, prices, webhook, and DB are all ready.
STRIPE_BILLING_ENABLED=false
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
NEXT_PUBLIC_STRIPE_PORTAL_RETURN_URL=/settings
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_TEAM_MONTHLY=
STRIPE_PRICE_TEAM_YEARLY=

# Weaviate and optional provider headers.
WEAVIATE_URL=
WEAVIATE_API_KEY=
WEAVIATE_GRPC_HOST=
WEAVIATE_GRPC_PORT=
WEAVIATE_GRPC_SECURE=
WEAVIATE_VECTORIZER=text2vec-openai
COHERE_API_KEY=

# RAG tunables.
ESVA_DEFAULT_TENANT_ID=esa
ESVA_RAG_ALPHA=0.7
ESVA_RAG_FETCH_CAP=50
ESVA_RAG_SNIPPET_MAX_CHARS=500
ESVA_RAG_FRESHNESS_MAX_BOOST=1.15
ESVA_RAG_FRESHNESS_HALF_LIFE_DAYS=365

# Sentry. Client and server DSNs are separate trust boundaries.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_BUILD_ID=

# App and request origins.
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ALLOWED_ORIGINS=
NODE_ENV=development
LOG_LEVEL=info
OPEN_BETA=true

# Public feature flags. Drawing parser defaults true; notarization defaults false.
NEXT_PUBLIC_FF_DRAWING_PARSER=true
NEXT_PUBLIC_FF_RECEIPT_NOTARIZE=false

# Operational authentication and contact privacy.
HEALTHCHECK_TOKEN=
INTERNAL_API_SECRET=
ADMIN_API_TOKEN=
CRON_SECRET=
FEEDBACK_IP_HASH_SECRET=
CONTACT_IP_HASH_SECRET=
FIELD_SOS_RECIPIENT_UIDS=

# On-premise AI exact origin allowlist, comma-separated.
# Example: http://127.0.0.1:11434,http://192.168.1.100:8000
ONPREMISE_ALLOWED_ORIGINS=

# Durable storage. Keep ephemeral storage false in production.
ESVA_ALLOW_EPHEMERAL_STORAGE=false
DRAWING_JOB_STORE_DIR=
DRAWING_SOURCE_LEASE_SECRET=

# SLD V3 signed external evaluation receipt.
# Receipt and public-key paths must stay under data/sld-evaluation/.
SLD_V3_EVAL_RECEIPT_PATH=
SLD_V3_EVAL_PUBLIC_KEY_PATH=
SLD_V3_EVAL_REQUIRED_STRATA=

# Legacy SLD golden claim gate. Missing evidence must fail closed.
SLD_GOLDEN_GATE_PUBLIC_KEY_PEM=
SLD_GOLDEN_MANIFEST_PATH=
SLD_GOLDEN_RECEIPT_PATH=
SLD_GOLDEN_ATTESTATION_PUBLIC_KEY_PATH=
SLD_GOLDEN_ATTESTATION_KEY_SHA256=
SLD_GOLDEN_RECEIPT_SIGNING_PRIVATE_KEY_PATH=

# Optional IPFS timestamp registration. Feature flag remains off by default.
PINATA_JWT=
PINATA_GATEWAY=https://gateway.pinata.cloud

# Optional solar irradiance lookup.
KMA_API_KEY=
